# Optional local environment variables for fd_dev
# Copy this file to .env for local development. Never commit real keys or tokens.

# Optional Yelp API token used only when real-address lookup is enabled.
YELP_API_KEY=

# Optional app path overrides.
FTID_BASE_DIR=
FTID_OUTPUT_DIR=
FTID_STATE_DIR=

# Optional debug logging. Use 1, true, or yes to enable.
FTID_DEBUG=0

# Optional Java/ZXing override.
ZXING_STANDALONE_JAR_PATH=
